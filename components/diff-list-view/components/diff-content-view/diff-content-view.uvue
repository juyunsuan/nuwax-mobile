      flex-shrink: 0;
    }

    .line-sign {
      width: 36rpx;
      text-align: center;
      font-weight: bold;
      user-select: none;
      font-family: monospace;
      font-size: 22rpx;
      flex-shrink: 0;
    }

    .line-content {
      padding-left: 12rpx;
      font-family: monospace, Courier, monospace;
      word-break: break-all;

      &.no-wrap-style {
        white-space: pre;
        flex: none;
      }
    }

    /* 样式变体 */
    &.normal {
      background-color: #ffffff;
    }

    &.added {
      background-color: rgba(46, 160, 67, 0.12);

      .line-number.new-num {
        background-color: rgba(46, 160, 67, 0.22);
        color: #1a7f37;
      }

      .line-sign,
      .line-content {
        color: #1a7f37;
      }
    }

    &.removed {
      background-color: rgba(248, 81, 73, 0.12);

      .line-number.old-num {
        background-color: rgba(248, 81, 73, 0.22);
        color: #cf222e;
      }

      .line-sign,
      .line-content {
        color: #cf222e;
      }
