<template>
  <view class="diff-content-wrapper">
    <!-- Diff 内容展示区：双层 scroll-view 嵌套模型（外层作为视口测量隔离，禁止垂直滚动） -->
    <scroll-view :scroll-y="false" class="diff-scroll-view-y">
      <!-- 内层负责横向水平滚动 -->
      <scroll-view
        :scroll-x="true"
        direction="horizontal"
        class="diff-scroll-view-x"
      >
        <view class="diff-table">
          <view
            v-for="(line, index) in diffLinesList"
            :key="index"
            :class="['diff-line', line.type]"
          >
            <!-- 旧行号 -->
            <text class="line-number old-num">{{ line.oldLineNum }}</text>
            <!-- 新行号 -->
            <text class="line-number new-num">{{ line.newLineNum }}</text>
            <!-- 标志 (+ / - / 空) -->
            <text class="line-sign">{{
              line.type === "added" ? "+" : line.type === "removed" ? "-" : " "
            }}</text>
            <!-- 代码/文本内容 -->
            <text class="line-content no-wrap-style">{{ line.content }}</text>
          </view>
        </view>
      </scroll-view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
  import { DiffLineItem } from "../../types";

  defineProps({
    diffLinesList: {
      type: Array as () => DiffLineItem[],
      required: true,
    },
  });
</script>

