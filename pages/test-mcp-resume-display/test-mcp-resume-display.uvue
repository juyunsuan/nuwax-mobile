<template>
  <view class="demo-page">
    <custom-nav-bar
      :title="t('Mobile.Intervention.Test.resumeDisplayDemoTitle')"
      :show-back="true"
    />

    <scroll-view class="demo-scroll" scroll-y="true">
      <view class="demo-container">
        <text class="demo-desc">{{
          t("Mobile.Intervention.Test.resumeDisplayDemoDesc")
        }}</text>

        <view class="legend">
          <text class="legend-item"
            >{{ t("Mobile.Intervention.Test.resumeDisplayImageLabel") }}：{{
              supportedImageExtText
            }}</text
          >
          <text class="legend-item"
            >{{ t("Mobile.Intervention.Test.resumeDisplayFileLabel") }}：{{
              unsupportedFileExtText
            }}</text
          >
          <text class="legend-item">{{
            t("Mobile.Intervention.Test.resumeDisplayExtensionlessHint")
          }}</text>
        </view>

        <view class="section">
          <text class="section-title">{{
            t("Mobile.Intervention.Test.resumeDisplayCombinedSection")
          }}</text>
          <view class="bubble">
            <mcp-ask-resume-user-display :text="COMBINED_RESUME_MESSAGE" />
          </view>
        </view>

        <view class="section">
          <text class="section-title">{{
            t("Mobile.Intervention.Test.resumeDisplayCasesSection")
          }}</text>
          <view
            v-for="caseItem in allCases"
            :key="caseItem.id"
            class="case-card"
          >
            <view class="case-header">
              <text class="case-ext">{{ caseItem.extension }}</text>
              <text
                class="case-tag"
                :class="
                  resolveRenderMode(caseItem) === getExpectedMode(caseItem)
                    ? 'case-tag--ok'
                    : 'case-tag--bad'
                "
              >
                {{ resolveRenderMode(caseItem) }}
              </text>
            </view>
            <text class="case-meta"
              >isRemoteImageUrl: {{ String(isRemoteImageUrl(caseItem.url)) }} ·
              isRemoteFileUrl: {{ String(isRemoteFileUrl(caseItem.url)) }}</text
            >
            <text v-if="caseItem.note" class="case-note">{{
              caseItem.note
            }}</text>
            <view class="bubble case-bubble">
              <mcp-ask-resume-user-display
                :text="buildResumeMessageForCase(caseItem)"
              />
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
  /**
   * MCP Ask resume 用户消息展示 Demo
   * 路由：/pages/test-mcp-resume-display/test-mcp-resume-display
   */
  import CustomNavBar from "@/components/custom-nav-bar/custom-nav-bar.uvue";
  import McpAskResumeUserDisplay from "@/components/mcp-ask-resume-user-display/mcp-ask-resume-user-display.uvue";
  import { computed } from "vue";
  import { t } from "@/utils/i18n.uts";
  import {
    COMBINED_RESUME_MESSAGE,
    EXTENSIONLESS_CASES,
    SINGLE_TYPE_CASES,
    SUPPORTED_IMAGE_EXTENSIONS,
    UNSUPPORTED_FILE_EXTENSIONS,
    buildResumeMessageForCase,
    type ResumeDisplayCase,
  } from "@/utils/mockMcpAskResumeDisplay.uts";
  import {
    isRemoteFileUrl,
    isRemoteImageUrl,
    parseMcpAskResumeDisplayContent,
  } from "@/subpackages/utils/mcpAskResumeMessage";

  const allCases = computed((): ResumeDisplayCase[] => {
    return [...SINGLE_TYPE_CASES, ...EXTENSIONLESS_CASES];
  });

  const supportedImageExtText = SUPPORTED_IMAGE_EXTENSIONS.join(" / ");
  const unsupportedFileExtText = UNSUPPORTED_FILE_EXTENSIONS.join(" / ");

  const getExpectedMode = (caseItem: ResumeDisplayCase): string => {
    return caseItem.expectedKind === "image"
      ? "inline-image"
      : "inline-document";
  };

  const resolveRenderMode = (caseItem: ResumeDisplayCase): string => {
    const parsed = parseMcpAskResumeDisplayContent(
      buildResumeMessageForCase(caseItem),
    );
    if (parsed.kind !== "resume" || !parsed.fields?.length) {
      return "plain";
    }
    const field = parsed.fields[0];
    if (field.imageUrls?.length) {
      return "inline-image";
    }
    if (field.fileUrls?.length) {
      return "inline-document";
    }
    return "text";
  };
</script>

