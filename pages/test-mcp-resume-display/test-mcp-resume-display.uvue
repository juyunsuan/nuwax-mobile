<template>
  <view class="demo-page">
    <custom-nav-bar
      :title="t('Mobile.Intervention.Test.resumeDisplayDemoTitle')"
      :show-back="true"
    />

    <scroll-view class="demo-scroll" scroll-y="true">
      <view class="demo-container">
        <text class="demo-desc">{{
          t("Mobile.Intervention.Test.resumeDisplayDemoDesc")
        }}</text>

        <view class="section">
          <text class="section-title">{{
            t("Mobile.Intervention.Test.resumeDisplayCombinedSection")
          }}</text>
          <view class="bubble">
            <scroll-view
              class="files-container"
              direction="horizontal"
              :scroll-with-animation="true"
              :show-scrollbar="false"
            >
              <view class="files-list">
                <view
                  v-for="file in mockAttachments"
                  :key="file.fileKey"
                  class="files-box"
                  :class="
                    !file.mimeType.includes('image/')
                      ? 'files-box-file'
                      : 'files-box-image'
                  "
                >
                  <image
                    v-if="file.mimeType.includes('image/')"
                    class="image"
                    :src="file.fileUrl"
                    mode="aspectFill"
                  />
                  <template v-else>
                    <text class="doc-name">{{ file.fileName }}</text>
                  </template>
                </view>
              </view>
            </scroll-view>
            <text class="preview-text">{{ displayText }}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
  /**
   * MCP Ask resume 用户消息展示 Demo
   * 普通文本 + message.attachments，无正文 URL 解析。
   * 路由：/pages/test-mcp-resume-display/test-mcp-resume-display
   */
  import CustomNavBar from "@/components/custom-nav-bar/custom-nav-bar.uvue";
  import { computed } from "vue";
  import { t } from "@/utils/i18n.uts";
  import { COMBINED_RESUME_MESSAGE } from "@/utils/mockMcpAskResumeDisplay.uts";
  import { stripMcpAskResumeDisplayArtifacts } from "@/subpackages/utils/mcpAskResumeMessage";
  import type { AttachmentFile } from "@/types/interfaces/conversationInfo.uts";

  const displayText = computed((): string => {
    return stripMcpAskResumeDisplayArtifacts(COMBINED_RESUME_MESSAGE);
  });

  const mockAttachments = [
    {
      fileKey: "k1",
      fileUrl: "https://cdn.example.com/a.png",
      fileName: "a.png",
      mimeType: "image/png",
      fileSize: 0,
    },
    {
      fileKey: "k2",
      fileUrl: "https://cdn.example.com/b.pdf",
      fileName: "b.pdf",
      mimeType: "application/pdf",
      fileSize: 0,
    },
  ] as AttachmentFile[];
</script>

